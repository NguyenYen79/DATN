from pymodbus.client import ModbusSerialClient

client = ModbusSerialClient(
    port="/dev/ttyACM1",
    baudrate=9600,
    parity="E",
    stopbits=1,
    bytesize=8,
    timeout=3
)

if client.connect():
    print("✅ Kết nối OK")
    result = client.read_holding_registers(address=0x0BB8, count=2, slave=1)
    print("Kết quả:", result)
    if hasattr(result, 'registers'):
        print("Registers:", result.registers)
    else:
        print("Lỗi:", result)
    client.close()
else:
    print("❌ Không kết nối được")
